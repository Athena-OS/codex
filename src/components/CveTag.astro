---
// src/components/CveTag.astro
//
// Renders a badge linking to the NIST NVD entry for a CVE. Used at the
// top of every Codex page that's tied to a specific CVE (where applicable).
//
// Usage in .mdx frontmatter:
//
//   ---
//   cve: [CVE-2020-1938]            # Ghostcat / AJP file inclusion
//   cve: [CVE-2017-12615, CVE-2020-1938]  # multiple
//   ---
//
// CVE IDs are passed through verbatim (no lookup table needed - the ID
// IS the canonical name, and the URL pattern is deterministic).

interface Props {
  /** CVE identifier, e.g. "CVE-2020-1938" */
  id: string;
}

const { id } = Astro.props;
const url = `https://nvd.nist.gov/vuln/detail/${id}`;
const tooltip = `View ${id} on NIST NVD`;
---

<a
  href={url}
  class="codex-cve-tag"
  target="_blank"
  rel="noopener noreferrer"
  title={tooltip}
>
  {/* Alert-triangle icon - common CVE visual shorthand */}
  <svg
    class="codex-cve-tag__icon"
    width="11"
    height="11"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"></path>
    <line x1="12" y1="9" x2="12" y2="13"></line>
    <line x1="12" y1="17" x2="12.01" y2="17"></line>
  </svg>
  <span class="codex-cve-tag__id">{id}</span>
  <svg
    class="codex-cve-tag__external"
    width="10"
    height="10"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
    <polyline points="15 3 21 3 21 9"></polyline>
    <line x1="10" y1="14" x2="21" y2="3"></line>
  </svg>
</a>

<style>
  .codex-cve-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--codex-accent-soft);
    color: var(--codex-accent);
    padding: 4px 10px;
    border-radius: var(--codex-radius-sm);
    font-size: 11px;
    font-family: var(--codex-font-mono);
    text-decoration: none;
    border: 1px solid var(--codex-accent-border);
    line-height: 1.3;
    transition: all 0.15s ease;
    margin-right: 6px;
    margin-bottom: 6px;
    vertical-align: middle;
  }

  .codex-cve-tag:hover {
    background: var(--codex-accent-softer);
    border-color: var(--codex-accent-border-strong);
    transform: translateY(-1px);
  }

  .codex-cve-tag:focus-visible {
    outline: 2px solid var(--codex-accent);
    outline-offset: 2px;
  }

  .codex-cve-tag__icon {
    flex-shrink: 0;
    opacity: 0.85;
  }

  .codex-cve-tag__id {
    font-weight: 500;
  }

  .codex-cve-tag__external {
    opacity: 0.5;
    flex-shrink: 0;
  }
</style>
