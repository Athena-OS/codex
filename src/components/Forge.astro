    // Placeholder substitution from OperatorConsole's localStorage
    const FIELD_MAP = {
      '<TARGET>':        'target',
      '<INTERNAL_HOST>': 'target',
      '<ATTACKER>':      'attacker',
      '<ATTACKER_IP>':   'attacker',
      '<COLLAB>':        'attacker',
      '<LHOST>':         'attacker',
      '<LPORT>':         'lport',
      '<USER>':          'user',
      '<DOMAIN>':        'domain',
      // Hoaxshell session ID components. These are NOT stored in
      // OperatorConsole — they're generated fresh by the running listener
      // for each session. Map to undefined storage keys so they always
      // render as dashed-pill placeholders, reminding the operator to
      // substitute them with values from their listener's printed payload.
      '<SID1>':          '_sid1',
      '<SID2>':          '_sid2',
      '<SID3>':          '_sid3',
    };
    const STORAGE_PREFIX = 'codex.op.';
    const TOKENS = Object.keys(FIELD_MAP).sort(function (a, b) { return b.length - a.length; });
    const TOKEN_RE = new RegExp(
      TOKENS.map(function (t) { return t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }).join('|'),
      'g'
    );

    function readState() {
      const s = { target: '', attacker: '', lport: '', user: '', domain: '' };
      try {
        for (const k in s) {
          const v = localStorage.getItem(STORAGE_PREFIX + k);
          if (v) s[k] = v;
        }
      } catch (e) {}
      return s;
    }

    function resolveCmd(template) {
      const state = readState();
      return template.replace(TOKEN_RE, function (token) {
        const key = FIELD_MAP[token];
        return state[key] || token;
      });
    }

    function renderCmdFragment(template) {
      const frag = document.createDocumentFragment();
      const state = readState();
      let lastIndex = 0;
      TOKEN_RE.lastIndex = 0;
      let m;
      while ((m = TOKEN_RE.exec(template)) !== null) {
        if (m.index > lastIndex) {
          frag.appendChild(document.createTextNode(template.slice(lastIndex, m.index)));
        }
        const token = m[0];
        const key = FIELD_MAP[token];
        const span = document.createElement('span');
        if (state[key]) {
          span.className = 'codex-op-sub';
          span.textContent = state[key];
        } else {
          span.className = 'codex-forge__placeholder';
          span.textContent = token;
        }
        frag.appendChild(span);
        lastIndex = m.index + token.length;
      }
      if (lastIndex < template.length) {
        frag.appendChild(document.createTextNode(template.slice(lastIndex)));
      }
      return frag;
    }

    const COPY_ICON = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
    const CHEVRON_ICON = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>';

    function buildPayloadPane(paneEl, key) {
      const items = PAYLOADS[key];
      if (!items || !items.length) return;

      // Dropdown
      const dropdown = document.createElement('div');
      dropdown.className = 'codex-forge__dropdown';

      const trigger = document.createElement('button');
      trigger.type = 'button';
      trigger.className = 'codex-forge__dropdown-trigger';
      trigger.setAttribute('aria-haspopup', 'listbox');
      trigger.setAttribute('aria-expanded', 'false');

      const triggerLabel = document.createElement('span');
      triggerLabel.className = 'codex-forge__dropdown-label';
      triggerLabel.textContent = items[0].label;
      trigger.appendChild(triggerLabel);

      const triggerChev = document.createElement('span');
      triggerChev.className = 'codex-forge__dropdown-chev';
      triggerChev.innerHTML = CHEVRON_ICON;
      trigger.appendChild(triggerChev);

      dropdown.appendChild(trigger);

      const menu = document.createElement('ul');
      menu.className = 'codex-forge__dropdown-menu';
      menu.setAttribute('role', 'listbox');
      menu.setAttribute('aria-hidden', 'true');
      items.forEach(function (item, idx) {
        const li = document.createElement('li');
        li.className = 'codex-forge__dropdown-item';
        if (idx === 0) li.classList.add('codex-forge__dropdown-item--active');
        li.setAttribute('role', 'option');
        li.setAttribute('aria-selected', idx === 0 ? 'true' : 'false');
        li.setAttribute('data-idx', String(idx));
        const labelSpan = document.createElement('span');
        labelSpan.className = 'codex-forge__dropdown-item-label';
        labelSpan.textContent = item.label;
        li.appendChild(labelSpan);
        const metaSpan = document.createElement('span');
        metaSpan.className = 'codex-forge__dropdown-item-meta';
        metaSpan.textContent = item.meta;
        li.appendChild(metaSpan);
        menu.appendChild(li);
      });
      dropdown.appendChild(menu);
      paneEl.appendChild(dropdown);

      // Command box — flex layout:
      //   [ scrollable text region (flex: 1, overflow-x: auto) ][ copy btn ]
      // The button is a flex sibling, NOT absolute-positioned inside the
      // scroll area. This means horizontal scroll only affects the text;
      // the button stays put and doesn't overlap.
      const cmdWrap = document.createElement('div');
      cmdWrap.className = 'codex-forge__cmd';

      const cmdScroll = document.createElement('div');
      cmdScroll.className = 'codex-forge__cmd-scroll';
      const cmdCode = document.createElement('code');
      cmdCode.className = 'codex-forge__cmd-text';
      cmdScroll.appendChild(cmdCode);
      cmdWrap.appendChild(cmdScroll);

      const copyBtn = document.createElement('button');
      copyBtn.type = 'button';
      copyBtn.className = 'codex-forge__copy codex-forge__copy--cmd';
      copyBtn.setAttribute('aria-label', 'Copy command');
      copyBtn.innerHTML = COPY_ICON;
      cmdWrap.appendChild(copyBtn);

      paneEl.appendChild(cmdWrap);

      const metaLine = document.createElement('p');
      metaLine.className = 'codex-forge__cmd-meta';
      paneEl.appendChild(metaLine);

      let currentIdx = 0;
      function render() {
        const item = items[currentIdx];
        triggerLabel.textContent = item.label;
        cmdCode.innerHTML = '';
        cmdCode.appendChild(renderCmdFragment(item.cmd));
        metaLine.textContent = item.meta;
        // Reset horizontal scroll so each new command starts from the left.
        // Browsers preserve scrollLeft across content swaps by default —
        // good for chat-style content, wrong for switching to a different
        // command where the operator wants to see it from the beginning.
        cmdScroll.scrollLeft = 0;
        menu.querySelectorAll('.codex-forge__dropdown-item').forEach(function (li) {
          const isActive = parseInt(li.getAttribute('data-idx'), 10) === currentIdx;
          li.classList.toggle('codex-forge__dropdown-item--active', isActive);
          li.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
      }
      render();

      // Menu is appended to document.body when open so it escapes all
      // overflow contexts. Closed: menu sits in dropdown DOM as before
      // (but with opacity:0 + pointer-events:none, so invisible).

      function positionMenu() {
        // Compute fixed-position coords for the menu. Flip up if no room below.
        const tr = trigger.getBoundingClientRect();
        const estHeight = Math.min(items.length * 44 + 8, 280);
        const spaceBelow = window.innerHeight - tr.bottom;
        const spaceAbove = tr.top;
        const flipUp = spaceBelow < estHeight + 16 && spaceAbove > spaceBelow;
        menu.style.position = 'fixed';
        menu.style.left = tr.left + 'px';
        menu.style.width = tr.width + 'px';
        menu.style.zIndex = '10001';  // Above all floating buttons.
        if (flipUp) {
          menu.style.top = 'auto';
          menu.style.bottom = (window.innerHeight - tr.top + 4) + 'px';
          menu.style.maxHeight = Math.min(estHeight, spaceAbove - 16) + 'px';
        } else {
          menu.style.top = (tr.bottom + 4) + 'px';
          menu.style.bottom = 'auto';
          menu.style.maxHeight = Math.min(estHeight, spaceBelow - 16) + 'px';
        }
      }

      // Track menu's original DOM parent for restoration on close.
      const menuOriginalParent = dropdown;

      function setOpen(open) {
        dropdown.classList.toggle('codex-forge__dropdown--open', open);
        menu.setAttribute('aria-hidden', open ? 'false' : 'true');
        trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
        if (open) {
          // Move menu to body so it escapes clipping and overflow.
          // Once in body, the descendant rule
          //   .codex-forge__dropdown--open .codex-forge__dropdown-menu
          // no longer applies. Inline-set display:block AND the rest of
          // the open-state styles.
          if (menu.parentElement !== document.body) {
            document.body.appendChild(menu);
          }
          menu.style.display = 'block';
          positionMenu();
          menu.classList.add('codex-forge__dropdown-menu--open');
          openMenu = menu;
          openDropdown = dropdown;
        } else {
          // Clear all inline styles and put menu back into the dropdown.
          // When back in the dropdown, the CSS `display: none` (closed
          // default) takes over.
          menu.classList.remove('codex-forge__dropdown-menu--open');
          menu.style.display = '';
          menu.style.position = '';
          menu.style.top = '';
          menu.style.bottom = '';
          menu.style.left = '';
          menu.style.width = '';
          menu.style.maxHeight = '';
          menu.style.zIndex = '';
          if (menu.parentElement === document.body) {
            menuOriginalParent.appendChild(menu);
          }
          if (openMenu === menu) openMenu = null;
          if (openDropdown === dropdown) openDropdown = null;
        }
      }

      // Reposition on window resize while open
      window.addEventListener('resize', function () {
        if (dropdown.classList.contains('codex-forge__dropdown--open')) {
          positionMenu();
        }
      });
      trigger.addEventListener('click', function (e) {
        e.stopPropagation();
        const isOpen = dropdown.classList.contains('codex-forge__dropdown--open');
        // Close any other open dropdowns first
        if (openDropdown && openDropdown !== dropdown) {
          // Find the other dropdown's setOpen — store on element
          if (openDropdown._forgeSetOpen) openDropdown._forgeSetOpen(false);
        }
        setOpen(!isOpen);
      });

      // Expose setOpen for cross-dropdown closing
      dropdown._forgeSetOpen = setOpen;

      menu.querySelectorAll('.codex-forge__dropdown-item').forEach(function (li) {
        li.addEventListener('click', function () {
          currentIdx = parseInt(li.getAttribute('data-idx'), 10);
          render();
          setOpen(false);
        });
      });

      copyBtn.addEventListener('click', function () {
        copy(resolveCmd(items[currentIdx].cmd));
      });

      paneEl._forgeRender = render;
    }

    function buildAllPayloadPanes() {
      document.querySelectorAll('[data-forge-payload-pane]').forEach(function (paneEl) {
        const key = paneEl.getAttribute('data-forge-payload-pane');
        buildPayloadPane(paneEl, key);
      });
    }
    function rerenderAllPayloadPanes() {
      document.querySelectorAll('[data-forge-payload-pane]').forEach(function (paneEl) {
        if (paneEl._forgeRender) paneEl._forgeRender();
      });
    }

    // Close any open dropdown when clicking outside.
    // Because the menu is appended to document.body when open, it's not
    // a DOM descendant of the dropdown anymore. So we check against both
    // the open dropdown AND the open menu specifically.
    document.addEventListener('click', function (e) {
      if (!openDropdown) return;
      const insideDropdown = e.target.closest('.codex-forge__dropdown');
      const insideMenu = openMenu && (e.target === openMenu || openMenu.contains(e.target));
      if (insideDropdown === openDropdown || insideMenu) return;
      // Clicked outside — close the open dropdown
      if (openDropdown._forgeSetOpen) openDropdown._forgeSetOpen(false);
    });

    // ENCODERS
    function strToBytes(s) { return new TextEncoder().encode(s); }
    function bytesToStr(b) { return new TextDecoder('utf-8', { fatal: false }).decode(b); }
    function bytesToB64(bytes) {
      let s = '';
      for (let i = 0; i < bytes.length; i++) s += String.fromCharCode(bytes[i]);
      return btoa(s);
    }
    function b64ToBytes(b64) {
      const s = atob(b64.replace(/\s+/g, ''));
      const out = new Uint8Array(s.length);
      for (let i = 0; i < s.length; i++) out[i] = s.charCodeAt(i);
      return out;
    }

    const ENCODERS = {
      url: {
        encode: function (s) { return encodeURIComponent(s); },
        decode: function (s) { try { return decodeURIComponent(s); } catch (e) { return '⚠ malformed URL-encoded input'; } },
      },
      base64: {
        encode: function (s) { return bytesToB64(strToBytes(s)); },
        decode: function (s) { try { return bytesToStr(b64ToBytes(s)); } catch (e) { return '⚠ malformed base64 input'; } },
      },
      'base64-utf16le': {
        encode: function (s) {
          const bytes = new Uint8Array(s.length * 2);
          for (let i = 0; i < s.length; i++) {
            const c = s.charCodeAt(i);
            bytes[i * 2] = c & 0xff;
            bytes[i * 2 + 1] = (c >> 8) & 0xff;
          }
          return bytesToB64(bytes);
        },
        decode: null,
      },
      hex: {
        encode: function (s) {
          const b = strToBytes(s);
          let out = '';
          for (let i = 0; i < b.length; i++) out += b[i].toString(16).padStart(2, '0');
          return out;
        },
        decode: function (s) {
          const cleaned = s.replace(/0x|\\x|,|\s+/g, '');
          if (!/^[0-9a-fA-F]*$/.test(cleaned) || cleaned.length % 2 !== 0) return '⚠ malformed hex input';
          const bytes = new Uint8Array(cleaned.length / 2);
          for (let i = 0; i < cleaned.length; i += 2) bytes[i / 2] = parseInt(cleaned.substr(i, 2), 16);
          try { return bytesToStr(bytes); } catch (e) { return '⚠ malformed hex input'; }
        },
      },
      html: {
        encode: function (s) {
          return s.replace(/[&<>"'\/]/g, function (c) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#x27;', '/': '&#x2F;' }[c];
          });
        },
        decode: function (s) {
          const t = document.createElement('textarea');
          t.innerHTML = s;
          return t.value;
        },
      },
      unicode: {
        encode: function (s) {
          let out = '';
          for (let i = 0; i < s.length; i++) {
            const c = s.charCodeAt(i);
            out += '\\u' + c.toString(16).padStart(4, '0');
          }
          return out;
        },
        decode: function (s) {
          try {
            return s.replace(/\\u\{([0-9a-fA-F]+)\}/g, function (_, h) {
              return String.fromCodePoint(parseInt(h, 16));
            }).replace(/\\u([0-9a-fA-F]{4})/g, function (_, h) {
              return String.fromCharCode(parseInt(h, 16));
            });
          } catch (e) { return '⚠ malformed \\u escapes'; }
        },
      },
      jwt: {
        encode: function (s) { return decodeJwt(s); },
        decode: null,
      },
    };

    function decodeJwt(token) {
      const t = token.trim();
      const parts = t.split('.');
      if (parts.length < 2) return '⚠ not a JWT (needs at least header.payload)';
      function b64url(p) {
        let b = p.replace(/-/g, '+').replace(/_/g, '/');
        while (b.length % 4) b += '=';
        try { return bytesToStr(b64ToBytes(b)); } catch (e) { return null; }
      }
      const h = b64url(parts[0]);
      const p = b64url(parts[1]);
      if (!h || !p) return '⚠ malformed JWT base64url';
      function pretty(s) { try { return JSON.stringify(JSON.parse(s), null, 2); } catch (e) { return s; } }
      return '─── header ───\n' + pretty(h) + '\n\n─── payload ───\n' + pretty(p) +
             (parts[2] ? '\n\n─── signature ───\n' + parts[2] + '\n(not verified)' : '');
    }

    function wireEncoders() {
      document.querySelectorAll('#codex-forge [data-forge-encoder]').forEach(function (encEl) {
        const kind = encEl.getAttribute('data-forge-encoder');
        const input = encEl.querySelector('.codex-forge__enc-in');
        const output = encEl.querySelector('.codex-forge__enc-out');
        const copyBtn = encEl.querySelector('[data-forge-enc-copy]');
        const dirBtns = encEl.querySelectorAll('[data-dir]');
        let currentDir = 'encode';

        dirBtns.forEach(function (b) {
          b.addEventListener('click', function () {
            dirBtns.forEach(function (x) { x.classList.remove('codex-forge__dir--active'); });
            b.classList.add('codex-forge__dir--active');
            currentDir = b.getAttribute('data-dir');
            run();
          });
        });

        function run() {
          const raw = input.value;
          if (!raw) { output.textContent = ''; return; }
          const enc = ENCODERS[kind];
          if (!enc) { output.textContent = '⚠ unknown encoder'; return; }
          const fn = currentDir === 'decode' ? enc.decode : enc.encode;
          if (!fn) { output.textContent = ''; return; }
          try { output.textContent = fn(raw); }
          catch (e) { output.textContent = '⚠ ' + (e.message || 'encoding error'); }
        }
        input.addEventListener('input', run);

        copyBtn.addEventListener('click', function () {
          const text = output.textContent || '';
          if (!text) return;
          copy(text);
        });
      });
    }

    // Copy + toast
    const toast = document.querySelector('#codex-forge .codex-forge__toast');
    let toastTimer = null;
    function showToast(msg) {
      if (!toast) return;
      toast.textContent = msg;
      toast.classList.add('codex-forge__toast--visible');
      if (toastTimer) clearTimeout(toastTimer);
      toastTimer = setTimeout(function () {
        toast.classList.remove('codex-forge__toast--visible');
      }, 1600);
    }
    function copy(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text)
          .then(function () { showToast('copied to clipboard'); })
          .catch(function () { fallbackCopy(text); });
      } else {
        fallbackCopy(text);
      }
    }
    function fallbackCopy(text) {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); showToast('copied to clipboard'); }
      catch (e) { showToast('copy failed'); }
      ta.remove();
    }

    // Tabs + panel
    function wireTabs() {
      const tabs = document.querySelectorAll('#codex-forge .codex-forge__tab');
      const panes = document.querySelectorAll('#codex-forge .codex-forge__pane');
      tabs.forEach(function (t) {
        t.addEventListener('click', function () {
          const name = t.getAttribute('data-forge-tab');
          tabs.forEach(function (x) {
            x.classList.toggle('codex-forge__tab--active', x === t);
            x.setAttribute('aria-selected', x === t ? 'true' : 'false');
          });
          panes.forEach(function (p) {
            const active = p.getAttribute('data-forge-pane') === name;
            p.classList.toggle('codex-forge__pane--active', active);
            if (active) p.removeAttribute('hidden');
            else p.setAttribute('hidden', '');
          });
        });
      });
    }

    function wirePanel() {
      const root = document.getElementById('codex-forge');
      const panel = document.getElementById('codex-forge-panel');
      const toggleBtn = root && root.querySelector('.codex-forge__toggle');
      const closeBtn = root && root.querySelector('.codex-forge__close');
      if (!root || !panel || !toggleBtn) return;

      function setOpen(open) {
        panel.setAttribute('aria-hidden', open ? 'false' : 'true');
        toggleBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
        root.classList.toggle('codex-forge--open', open);
        if (open) rerenderAllPayloadPanes();
      }
      toggleBtn.addEventListener('click', function () {
        const isOpen = panel.getAttribute('aria-hidden') === 'false';
        setOpen(!isOpen);
      });
      if (closeBtn) closeBtn.addEventListener('click', function () { setOpen(false); });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && panel.getAttribute('aria-hidden') === 'false') {
          setOpen(false);
          toggleBtn.focus();
        }
      });
    }

    function init() {
      wirePanel();
      wireTabs();
      buildAllPayloadPanes();
      wireEncoders();

      // Live-rerender Forge command displays when OperatorConsole state
      // changes. Without this, Forge would only refresh on panel-open —
      // a stale placeholder (or "hardcoded" value after a clear) would
      // persist until the user manually toggled the panel.
      document.addEventListener('codex:op:change', function () {
        rerenderAllPayloadPanes();
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style is:global>
